# Copy this to .env and fill in your real values
# NEVER commit .env to GitHub — add it to .gitignore

# PostgreSQL — local dev
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mediakit

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Get from console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# YouTube Data API v3 — same Google Cloud project as OAuth
YOUTUBE_API_KEY=your-youtube-api-key

# From developers.facebook.com
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# Where your Next.js frontend runs
FRONTEND_URL=http://localhost:3000

# Where your FastAPI backend runs
BACKEND_URL=http://localhost:8000
